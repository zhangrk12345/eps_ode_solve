    "# 第一次作业\n",
    "班级：xxx  学号：xxx  姓名：xxx\n",
    "\n",
    "## 第一题 奇异摄动微分方程求解与收敛验证\n",
    "$$\n",
    "\\begin{cases}\n",
    "-\\varepsilon u''(x)+|u'(x)|-1=0,\\quad -1<x<1 \\\\\n",
    "u(-1)=u(1)=0\n",
    "\\end{cases}\n",
    "$$"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "import numpy as np\n",
    "from scipy.integrate import solve_ivp\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "def ode(x, y, eps):\n",
    "    u, du = y\n",
    "    dudx = du\n",
    "    d2udx2 = (abs(du) - 1) / eps\n",
    "    return [dudx, d2udx2]\n",
    "\n",
    "def target(s, eps):\n",
    "    res = solve_ivp(lambda x,y: ode(x,y,eps), [-1, 1], [0, s], t_eval=[1])\n",
    "    return res.y[0, -1]\n",
    "\n",
    "def solve_bvp(eps):\n",
    "    low, high = -5, 5\n",
    "    for _ in range(80):\n",
    "        mid = (low + high) / 2\n",
    "        val = target(mid, eps)\n",
    "        if val > 0:\n",
    "            high = mid\n",
    "        else:\n",
    "            low = mid\n",
    "    s_opt = (low + high) / 2\n",
    "    x_grid = np.linspace(-1, 1, 400)\n",
    "    sol_full = solve_ivp(lambda x,y: ode(x,y,eps), [-1,1], [0, s_opt], t_eval=x_grid)\n",
    "    return sol_full, s_opt\n",
    "\n",
    "eps_list = [0.5, 0.1, 0.01, 0.001]\n",
    "x_ref = np.linspace(-1,1,400)\n",
    "u_ref = 1 - np.abs(x_ref)\n",
    "\n",
    "plt.figure(figsize=(10,5))\n",
    "plt.plot(x_ref, u_ref, 'k--', label=r'极限解 $u=1-|x|$', lw=3)\n",
    "for eps in eps_list:\n",
    "    sol, s_opt = solve_bvp(eps)\n",
    "    plt.plot(sol.t, sol.y[0], label=f'$\\epsilon={eps}$')\n",
    "plt.xlabel('$x$')\n",
    "plt.ylabel('$u_\\epsilon(x)$')\n",
    "plt.title('消失粘性收敛验证')\n",
    "plt.legend()\n",
    "plt.grid()\n",
    "plt.show()\n",
    "\n",
    "for eps in eps_list:\n",
    "    _, s_opt = solve_bvp(eps)\n",
    "    print(f'ε={eps}, u\'(-1)={s_opt:.4f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "source": [
    "---\n",
    "## 第二题 秘书问题\n",
    "### 1. 数学建模\n",
    "共N个候选人，采用观望k策略，成功概率 $P(k)=\\frac{k}{N}\\sum_{i=k}^{N-1}\\frac1i$\n",
    "### 2. 最优策略\n",
    "先拒绝前 $1/e\\approx37\\%$ 的人，录用第一个比前面所有人都优秀的候选人"
   ]
  },
  {
   "cell_type": "code",
   "source": [
    "import math\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "def prob(N, k):\n",
    "    s=0\n",
    "    for i in range(k,N):\n",
    "        s += 1/i\n",
    "    return k/N * s\n",
    "\n",
    "def best_k(N):\n",
    "    max_p=0\n",
    "    best=0\n",
    "    for k in range(N):\n",
    "        p=prob(N,k)\n",
    "        if p>max_p:\n",
    "            max_p=p\n",
    "            best=k\n",
    "    return best, max_p\n",
    "\n",
    "for N in [10,50,100,500]:\n",
    "    k,p=best_k(N)\n",
    "    print(f'N={N},最优观望人数{k},比例{k/N:.3f},成功率{p:.3f}')\n",
    "\n",
    "N=200\n",
    "ks=np.arange(N)\n",
    "ps=[prob(N,k) for k in ks]\n",
    "plt.plot(ks/N,ps)\n",
    "plt.axvline(1/math.e,c='r',ls='--')\n",
    "plt.xlabel('观望比例k/N')\n",
    "plt.ylabel('选中最优概率')\n",
    "plt.show()"
   ]
  }
