   "source": [
    "import numpy as np\n",
    "from scipy.integrate import solve_ivp\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 奇异摄动ODE：-ε u'' + |u'| - 1 = 0\n",
    "# 令 y1=u, y2=u'  => y1'=y2,  y2' = (|y2| - 1)/ε\n",
    "def ode(x, y, eps):\n",
    "    u, du = y\n",
    "    dudx = du\n",
    "    d2udx2 = (abs(du) - 1) / eps\n",
    "    return [dudx, d2udx2]\n",
    "\n",
    "# 打靶法目标：给定左端点导数s，计算u(1)\n",
    "def target(s, eps):\n",
    "    res = solve_ivp(lambda x,y: ode(x,y,eps), [-1, 1], [0, s], t_eval=[1])\n",
    "    return res.y[0, -1]\n",
    "\n",
    "# 二分法寻找满足u(1)=0的初值s\n",
    "def solve_bvp(eps):\n",
    "    low, high = -5, 5\n",
    "    for _ in range(80):\n",
    "        mid = (low + high) / 2\n",
    "        val = target(mid, eps)\n",
    "        if val > 0:\n",
    "            high = mid\n",
    "        else:\n",
    "            low = mid\n",
    "    s_opt = (low + high) / 2\n",
    "    # 完整求解整条曲线\n",
    "    x_grid = np.linspace(-1, 1, 400)\n",
    "    sol_full = solve_ivp(lambda x,y: ode(x,y,eps), [-1,1], [0, s_opt], t_eval=x_grid)\n",
    "    return sol_full, s_opt\n",
    "\n",
    "# 修改ε值观察边界层（ε越小边界层越明显）\n",
    "eps = 0.1\n",
    "sol, s_opt = solve_bvp(eps)\n",
    "\n",
    "# 绘图输出解曲线\n",
    "plt.figure(figsize=(9,4))\n",
    "plt.plot(sol.t, sol.y[0], linewidth=2)\n",
    "plt.title(r'$-\varepsilon u^{\\prime\\prime}+|u^\\prime|-1=0,\ u(\\pm1)=0,\ \\varepsilon=$'+f'{eps}')\n",
    "plt.xlabel('$x$')\n",
    "plt.ylabel('$u(x)$')\n",
    "plt.grid(alpha=0.3)\n",
    "plt.show()\n",
    "print(f'ε={eps} 时，左端点导数 u\\'(-1) = {s_opt:.5f}')"
   ]
  }
 ],
